# 必須: Anthropic APIキー (https://platform.claude.com/ で取得)
ANTHROPIC_API_KEY=sk-ant-...

# 任意: 使用モデルの上書き (デフォルト: claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# 任意: Supabase に評価JSONを保存する場合のみ設定
# 未設定の場合、評価JSONは生成されるが保存はスキップされる
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
