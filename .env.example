# 必須: Anthropic APIキー (https://platform.claude.com/ で取得)
ANTHROPIC_API_KEY=sk-ant-...

# 任意: 使用モデルの上書き (デフォルト: claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8

# 推奨: Supabase (キャリアカードのDB保存)
# supabase/schema.sql を実行してから設定してください。
# 未設定の場合、カードは生成されるが端末ローカル保存にフォールバックする
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...
